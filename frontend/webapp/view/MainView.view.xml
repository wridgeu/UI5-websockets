<mvc:View controllerName="org.mrb.ui5websockets.controller.MainView" xmlns:mvc="sap.ui.core.mvc" xmlns:control="org.mrb.ui5websockets.control" displayBlock="true" xmlns="sap.m">
    <Page id="page" title="{i18n>title}" titleAlignment="Center" enableScrolling="true" class="sapUiResponsivePadding--content">
        <subHeader>
            <Toolbar>
                <ToolbarSpacer />
                <Text text="Use the buttons to test WebSocket connections, messaging, and retry behavior." />
                <ToolbarSpacer />
            </Toolbar>
        </subHeader>
        <content>
            <HBox justifyContent="Center" class="sapUiSmallMarginTopBottom" wrap="Wrap">
                <VBox alignItems="Center" class="sapUiSmallMarginEnd">
                    <Title text="Connection" level="H5" class="sapUiSmallMarginBottom" />
                    <HBox>
                        <Button text="Init (PCP)" press=".setupPcp" icon="sap-icon://connected" tooltip="Connect via SapPcpWebSocket using subprotocol v10.pcp.sap.com" />
                        <Button
                            class="sapUiSmallMarginBegin"
                            text="Init (plain WS)"
                            press=".setupPlain"
                            icon="sap-icon://connected"
                            tooltip="Connect via a regular WebSocket without any subprotocol"
                        />
                        <Button class="sapUiSmallMarginBeginEnd" text="Send Ping" press=".sendPing" icon="sap-icon://outgoing-call" />
                        <Button text="Close" press=".closeConnection" icon="sap-icon://disconnected" />
                    </HBox>
                </VBox>
                <VBox alignItems="Center" class="sapUiSmallMarginBegin">
                    <Title text="Retry Testing" level="H5" class="sapUiSmallMarginBottom" />
                    <HBox>
                        <Button text="Server Close" press=".testRetryBackend" type="Attention" icon="sap-icon://decline" />
                        <Button class="sapUiSmallMarginBegin" text="Connection Drop" press=".testRetryFrontend" type="Attention" icon="sap-icon://error" />
                    </HBox>
                    <Text text="Requires an active connection." class="sapUiTinyMarginTop" />
                </VBox>
            </HBox>
            <Panel id="logPanel">
                <headerToolbar>
                    <Toolbar>
                        <Title text="Event Log" level="H5" />
                        <ToolbarSpacer />
                        <Button icon="sap-icon://delete" tooltip="Clear log" press=".clearLog" type="Transparent" />
                    </Toolbar>
                </headerToolbar>
                <content>
                    <control:EventLogTerminal id="eventLog" height="300px" />
                </content>
            </Panel>
        </content>
    </Page>
</mvc:View>
